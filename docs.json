{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Core Network",
  "colors": {
    "primary": "#0143BB",
    "light": "#3369D6",
    "dark": "#0135A0"
  },
  "favicon": "/favicon.svg",
